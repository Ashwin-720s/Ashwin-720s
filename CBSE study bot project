        "import subprocess\n",
        "import time\n",
        "import os\n",
        "\n",
        "# Ensure zstd is installed (required for ollama installation)\n",
        "try:\n",
        "    subprocess.run([\"which\", \"zstd\"], check=True, capture_output=True)\n",
        "except subprocess.CalledProcessError:\n",
        "    print(\"zstd not found, installing...\")\n",
        "    subprocess.run([\"sudo\", \"apt-get\", \"update\"], check=True)\n",
        "    subprocess.run([\"sudo\", \"apt-get\", \"install\", \"-y\", \"zstd\"], check=True)\n",
        "    print(\"zstd installed.\")\n",
        "\n",
        "# Ensure ollama is installed\n",
        "try:\n",
        "    subprocess.run([\"which\", \"ollama\"], check=True, capture_output=True)\n",
        "    print(\"Ollama executable found.\")\n",
        "except subprocess.CalledProcessError:\n",
        "    print(\"Ollama executable not found, attempting re-installation...\")\n",
        "    # Re-run ollama installation script\n",
        "    curl_process = subprocess.run([\"curl\", \"-fsSL\", \"https://ollama.com/install.sh\"], capture_output=True, text=True, check=True)\n",
        "    install_script = curl_process.stdout\n",
        "    subprocess.run([\"sh\"], input=install_script.encode('utf-8'), check=True)\n",
        "    print(\"Ollama re-installation attempt finished.\")\n",
        "\n",
