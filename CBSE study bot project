        "from datasets import Dataset\n",
        "from google.colab import files\n",
        "import json\n",
        "\n",
        "# Click \"Choose Files\" when it appears below, and select your training_data.json\n",
        "uploaded = files.upload()\n",
        "\n",
        "with open(\"training_data.json\") as f:\n",
        "    data = json.load(f)\n",
        "\n",
        "# Convert your {instruction, input, output} pairs into the chat message\n",
        "# format this notebook's chat template expects\n",
        "def to_conversation(example):\n",
        "    return {\n",
        "        \"conversations\": [\n",
        "            {\"role\": \"user\", \"content\": example[\"instruction\"]},\n",
        "            {\"role\": \"assistant\", \"content\": example[\"output\"]},\n",
        "        ]\n",
        "    }\n",
        "\n",
        "dataset = Dataset.from_list(data)\n",
        "dataset = dataset.map(to_conversation)\n",
        "\n",
        "# Apply the chat template formatting (this notebook uses a chat-based\n",
        "# template rather than the raw Alpaca string template)\n",
        "def formatting_prompts_func(examples):\n",
        "    convos = examples[\"conversations\"]\n",
        "    texts = [tokenizer.apply_chat_template(convo, tokenize=False, add_generation_prompt=False) for convo in convos]\n",
        "    return {\"text\": texts}\n",
        "\n",
        "dataset = dataset.map(formatting_prompts_func, batched=True)"
      ]
    },
